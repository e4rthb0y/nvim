#!/usr/bin/env bash

# Check for dependencies
check_dep_any() {
    local desc="$1"
    shift
    local cmd

    for cmd in "$@"; do
        if command -v "$cmd" >/dev/null 2>&1; then
            echo "✅ $desc is installed ($cmd)"
            return 0
        fi
    done

    echo "❌ $desc is missing."
    return 1
}

echo "Starting Neovim Configuration Doctor..."
echo "--------------------------------------"

check_dep_any "ripgrep" rg
check_dep_any "fd" fd fdfind
check_dep_any "fzf" fzf
check_dep_any "Node.js" node nodejs
check_dep_any "Python 3" python3
check_dep_any "Ruby" ruby
check_dep_any "StyLua" stylua
check_dep_any "Selene" selene

echo "--------------------------------------"
echo "Doctor check complete."
